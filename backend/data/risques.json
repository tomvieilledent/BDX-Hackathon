	"features": [
		{
			"name": "Carte interactive",
			"endpoint": "/api/map",
			"description": "Combine forêts (IGN) + risques incendie (Géorisques)",
			"params": [
				"lat",
				"lon",
				"radius"
			]
		}
	]
}