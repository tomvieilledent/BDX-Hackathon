{
	"risques": [
		{
			"type": "Inondation",
			"nom": "Inondation",
			"icone": "💧",
			"couleur": "#1565C0",
			"numero_urgence": "18",
			"consignes_urgence": [
				"Monter immédiatement en étage",
				"Couper l'électricité et le gaz",
				"Ne pas prendre la voiture",
				"Ne pas marcher dans l'eau"
			],
			"checklist_avant": [
				"Eau potable (3L/personne/jour)",
				"Lampe torche + piles",
				"Radio à piles",
				"Médicaments",
				"Documents importants"
			],
			"checklist_pendant": [
				"Couper électricité",
				"Monter en hauteur",
				"Appeler le 15 si personne en danger"
			],
			"detection": {
				"source": "georisques",
				"type_check": "flood",
				"endpoint": "/api/georisques",
				"niveau_alerte": "modéré",
				"titre_alerte": "Risque d'inondation"
			}
		},
		{
			"type": "Canicule",
			"nom": "Canicule",
			"icone": "🌡️",
			"couleur": "#E65100",
			"numero_urgence": "15",
			"consignes_urgence": [
				"Aller dans un espace frais",
				"Boire 1,5L d'eau par heure minimum",
				"Fermer volets côté soleil",
				"Vérifier les voisins âgés"
			],
			"checklist_avant": [
				"Ventilateur ou climatiseur",
				"Eau fraîche en stock",
				"Brumisateur"
			],
			"checklist_pendant": [
				"Ne pas sortir entre 12h et 16h",
				"Mouiller ses poignets",
				"Appeler le 15 si malaise"
			],
			"detection": {
				"source": "meteo",
				"endpoint": "/api/weather/forecast",
				"meteo_field": "temperature_mean",
				"seuil_min": 35,
				"niveau_alerte": "élevé",
				"titre_alerte": "Alerte Canicule",
				"message_template": "Température très élevée : {value}°C"
			}
		},
		{
			"type": "Industriel",
			"nom": "Accident industriel",
			"icone": "☢️",
			"couleur": "#4A148C",
			"numero_urgence": "18",
			"consignes_urgence": [
				"Se confiner immédiatement",
				"Fermer toutes les ouvertures",
				"Couper ventilation et clim",
				"Écouter France Bleu Gironde"
			],
			"checklist_avant": [
				"Tissu humide pour boucher aérations",
				"Radio à piles",
				"Eau et nourriture pour 24h"
			],
			"checklist_pendant": [
				"Ne pas téléphoner inutilement (libérer les lignes)",
				"Ne pas sortir",
				"Attendre le signal officiel de fin d'alerte"
			],
			"detection": {
				"source": "georisques",
				"type_check": "seveso",
				"endpoint": "/api/georisques/incendies-seveso",
				"niveau_alerte": "critique",
				"titre_alerte": "Site SEVESO à proximité",
				"message_template": "{name} - {status}"
			}
		},
		{
			"type": "Incendie",
			"nom": "Incendie",
			"icone": "🔥",
			"couleur": "#B91C1C",
			"numero_urgence": "18",
			"consignes_urgence": [
				"Appeler immédiatement le 18 ou le 112",
				"Évacuer les lieux en restant au ras du sol",
				"Ne jamais utiliser l’ascenseur",
				"Fermer portes et fenêtres derrière vous si possible"
			],
			"checklist_avant": [
				"Installer des détecteurs de fumée et tester régulièrement",
				"Prévoir un extincteur adapté et savoir l’utiliser",
				"Identifier les issues de secours et chemins d’évacuation",
				"Préparer un point de rassemblement à l’extérieur",
				"Ranger les produits inflammables à l’écart des sources de chaleur"
			],
			"checklist_pendant": [
				"Donner l’alerte et prévenir les occupants",
				"Couper le gaz et l’électricité si cela est possible sans danger",
				"Se diriger vers la sortie la plus proche en restant calme",
				"Se couvrir la bouche et le nez avec un tissu humide",
				"Ne pas revenir en arrière pour récupérer des objets"
			]
		}
